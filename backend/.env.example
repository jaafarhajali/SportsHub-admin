# ─── Server ────────────────────────────────────────────────
PORT=8080
FRONTEND_URL=https://your-frontend-url.example.com
Base_IMAGE_URL=http://localhost:8080/

# Comma-separated list of allowed CORS origins
CORS_ORIGINS=http://localhost:3000,https://your-frontend-url.example.com

# ─── Database ──────────────────────────────────────────────
# MongoDB Atlas SRV string. Keep the literal <DATABASE_PASSWORD> placeholder;
# server.js substitutes it at runtime with DATABASE_PASSWORD below.
DATABASE=mongodb+srv://<USER>:<DATABASE_PASSWORD>@<CLUSTER>.mongodb.net/sportshub?retryWrites=true&w=majority&appName=Cluster0
DATABASE_PASSWORD=replace-me

# ─── Auth ──────────────────────────────────────────────────
# Use a 32+ character random string in production.
JWT_SECRET=replace-me-with-a-long-random-string
JWT_EXPIRES_IN=7d

# ─── Email (SMTP) ──────────────────────────────────────────
EMAIL_FROM_NAME=SportsHub
EMAIL_FROM_EMAIL=no-reply@example.com
EMAIL_USERNAME=your-smtp-user@example.com
EMAIL_PASSWORD=your-smtp-app-password
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587

# ─── Google OAuth ──────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8080/api/auth/google/callback

# ─── AI ────────────────────────────────────────────────────
# Provider: "grok" or "gemini"
AI_PROVIDER=gemini
GROK_API_KEY=
GROK_MODEL=grok-3-mini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# ─── Sentry (optional) ─────────────────────────────────────
# Leave SENTRY_DSN empty in dev to disable. In production, paste your DSN
# from https://sentry.io/ → your project → Settings → Client Keys (DSN).
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
